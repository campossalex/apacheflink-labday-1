  "liveNow": true,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Orders",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "format": "table",
          "rawSql": "SELECT SUM(order_count) AS \"Total Orders\"\nFROM revenue_5m\nWHERE window_start >= $__timeFrom()::timestamp\n  AND window_end   <= $__timeTo()::timestamp",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total Revenue",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "currencyUSD",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(revenue), 0) AS \"Total Revenue\"\nFROM revenue_5m\nWHERE window_start >= $__timeFrom()::timestamp\n  AND window_end   <= $__timeTo()::timestamp",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Categories Tracked",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "unit": "short",
          "noValue": "0",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT category) AS \"Categories\"\nFROM revenue_5m\nWHERE window_start >= $__timeFrom()::timestamp\n  AND window_end   <= $__timeTo()::timestamp",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Revenue Over Time by Category",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "format": "time_series",
          "rawSql": "SELECT\n  window_start AS \"time\",\n  category,\n  revenue\nFROM revenue_5m\nWHERE $__timeFilter(window_start)\nORDER BY window_start",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "bargauge",
      "title": "Top Categories by Revenue",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "format": "table",
          "rawSql": "SELECT category, SUM(revenue) AS revenue\nFROM revenue_5m\nWHERE $__timeFilter(window_start)\nGROUP BY category\nORDER BY revenue DESC\nLIMIT 10",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "table",
      "title": "Revenue by Category (Detail)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "postgres", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "auto" }
        },
        "overrides": []
      },
      "options": {
        "footer": { "enablePagination": true, "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "revenue" }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${datasource}" },
          "format": "table",
          "rawSql": "SELECT\n  category,\n  SUM(order_count) AS orders,\n  SUM(revenue) AS revenue,\n  COUNT(DISTINCT window_start) AS windows\nFROM revenue_5m\nWHERE $__timeFilter(window_start)\nGROUP BY category\nORDER BY revenue DESC\nLIMIT 50",
          "refId": "A"
        }
      ]
    }

  ],

