      "pluginVersion": "1.2.11",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT word, COUNT(*) AS frequency FROM ( SELECT LOWER(TRIM(regexp_split_to_table( CONCAT(COALESCE(improvement_1,''), ' ', COALESCE(improvement_2,'')), '\\s+' ))) AS word FROM public.feedback_summary WHERE processed_at > NOW() - INTERVAL '3 hours' AND (improvement_1 IS NOT NULL OR improvement_2 IS NOT NULL) ) w WHERE LENGTH(word) > 4 AND word NOT IN ( 'with','that','this','from','have','been','they','their','there','when','what','will','more','your','each','also','should','staff','store','need','needs','ensure','improve','review','customer','better','could','would','about','which','these','order','make','time','consider','customers','provide','address','implement','service' ) GROUP BY word ORDER BY frequency DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Improvement Keywords — Word Cloud",
      "type": "magnesium-wordcloud-panel"
    },
